---
import { getSiteSettings } from '../lib/site-settings';

const { siteTitle, footerDescription, githubUrl, twitterUrl, linkedinUrl } = await getSiteSettings();
const hasSocials = githubUrl || twitterUrl || linkedinUrl;
const today = new Date();
---

<footer>
		<div class="footer-container">
			<div class="footer-content">
				<div class="footer-brand">
					<div class="footer-logo">
						<i class="bi bi-terminal-fill"></i>
						<span>{siteTitle}</span>
					</div>
					<p class="footer-description">
						{footerDescription}
					</p>
					{hasSocials && (
						<div class="footer-socials">
							{githubUrl && (
								<a href={githubUrl} target="_blank" rel="noopener" class="footer-social-link" aria-label="GitHub">
									<i class="bi bi-github"></i>
								</a>
							)}
							{twitterUrl && (
								<a href={twitterUrl} target="_blank" rel="noopener" class="footer-social-link" aria-label="Twitter / X">
									<i class="bi bi-twitter-x"></i>
								</a>
							)}
							{linkedinUrl && (
								<a href={linkedinUrl} target="_blank" rel="noopener" class="footer-social-link" aria-label="LinkedIn">
									<i class="bi bi-linkedin"></i>
								</a>
							)}
						</div>
					)}
				</div>
				<div class="footer-links">
					<div class="footer-section">
						<h4 class="footer-heading">Navigation</h4>
						<ul class="footer-nav">
							<li>
								<a href="/blog" class="footer-link">Blog</a>
							</li>
							<li>
								<a href="/about" class="footer-link">About</a>
							</li>
						</ul>
					</div>
					<div class="footer-section">
						<h4 class="footer-heading">Topics</h4>
						<ul class="footer-nav">
							<li>
								<span class="footer-link disabled">Artificial Intelligence</span>
							</li>
							<li>
								<span class="footer-link disabled">Web Development</span>
							</li>
							<li>
								<span class="footer-link disabled">Frameworks</span>
							</li>
						</ul>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p class="footer-copyright">&copy; {today.getFullYear()} {siteTitle}. All rights reserved.</p>
				<a href="/rss.xml" class="footer-rss">RSS Feed</a>
			</div>
		</div>
	</footer>

<!-- Bootstrap JS -->
<script>
	import "bootstrap/dist/js/bootstrap.bundle.min.js";
</script>

	<style>
		footer {
			background: var(--cyber-bg-code);
			color: var(--cyber-text-primary);
			padding: 4rem 1.5rem 2rem;
			border-top: 1px solid var(--cyber-border-color);
		}

		:global([data-bs-theme="light"]) footer {
			background: var(--cyber-bg-tertiary);
		}

		.footer-container {
			max-width: 1400px;
			margin: 0 auto;
		}

		.footer-content {
			display: grid;
			grid-template-columns: 1fr;
			gap: 3rem;
			margin-bottom: 3rem;
		}

		@media (min-width: 768px) {
			.footer-content {
				grid-template-columns: 1fr 1fr;
			}
		}

		.footer-brand {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.footer-logo {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			font-size: 1.25rem;
			font-weight: 700;
			color: var(--cyber-text-primary);
			background: var(--cyber-gradient-primary);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}

		.footer-logo i {
			background: var(--cyber-gradient-primary);
			color: #000;
			width: 32px;
			height: 32px;
			display: flex;
			align-items: center;
			justify-content: center;
			border-radius: var(--radius-md);
			font-size: 1rem;
		}

		.footer-description {
			color: var(--cyber-text-secondary);
			line-height: 1.6;
			max-width: 400px;
			margin: 0;
		}

		.footer-socials {
			display: flex;
			gap: 0.75rem;
			margin-top: 1rem;
		}

		.footer-social-link {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 36px;
			height: 36px;
			border-radius: var(--radius-md);
			border: 1px solid var(--cyber-border-color);
			color: var(--cyber-text-secondary);
			text-decoration: none;
			font-size: 1.125rem;
			transition: all var(--motion-duration-normal) var(--motion-ease);
		}

		.footer-social-link:hover {
			color: var(--cyber-primary);
			border-color: var(--cyber-primary);
			background: var(--cyber-primary-light);
		}

		.footer-links {
			display: grid;
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		@media (min-width: 640px) {
			.footer-links {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		.footer-section {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.footer-heading {
			font-size: 0.875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--cyber-text-primary);
			margin: 0;
		}

		.footer-nav {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}

		.footer-link {
			color: var(--cyber-text-secondary);
			text-decoration: none;
			font-size: 0.9375rem;
			transition: color var(--motion-duration-normal) var(--motion-ease);
		}

		.footer-link:hover {
			color: var(--cyber-primary);
			text-decoration: none;
		}

		.footer-link.disabled {
			color: var(--cyber-text-muted);
			cursor: default;
		}

		.footer-link.disabled:hover {
			color: var(--cyber-text-muted);
		}

		.footer-bottom {
			display: flex;
			flex-direction: column;
			gap: 1rem;
			padding-top: 2rem;
			border-top: 1px solid var(--cyber-border-color);
		}

		@media (min-width: 640px) {
			.footer-bottom {
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
			}
		}

		.footer-copyright {
			color: var(--cyber-text-secondary);
			font-size: 0.875rem;
			margin: 0;
		}

		.footer-rss {
			color: var(--cyber-primary);
			text-decoration: none;
			font-size: 0.875rem;
			font-weight: 500;
			transition: color var(--motion-duration-normal) var(--motion-ease);
		}

		.footer-rss:hover {
			color: var(--cyber-primary-hover);
			text-decoration: underline;
		}

		@media (max-width: 768px) {
			footer {
				padding: 3rem 1.5rem 2rem;
			}
		}
	</style>
