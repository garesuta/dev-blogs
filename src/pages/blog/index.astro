---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { db } from '../../lib/db';
import { categories, posts as postsTable, users } from '../../lib/schema';
import { asc, desc, eq, and } from 'drizzle-orm';

export const prerender = false;

// Fetch categories from DB
const allCategories = await db
  .select()
  .from(categories)
  .orderBy(asc(categories.name));

// Get filter from URL
const url = Astro.url;
const categoryFilter = url.searchParams.get('category');

// Find category ID if filtering
let categoryId: string | null = null;
if (categoryFilter) {
  const matchedCategory = allCategories.find(c => c.slug === categoryFilter);
  categoryId = matchedCategory?.id || null;
}

// Fetch published posts from DB with optional category filter
const postsQuery = db
  .select({
    id: postsTable.id,
    slug: postsTable.slug,
    title: postsTable.title,
    description: postsTable.description,
    heroImage: postsTable.heroImage,
    status: postsTable.status,
    publishedAt: postsTable.publishedAt,
    createdAt: postsTable.createdAt,
    categoryId: postsTable.categoryId,
    authorId: postsTable.authorId,
    authorName: users.name,
  })
  .from(postsTable)
  .leftJoin(users, eq(postsTable.authorId, users.id))
  .where(
    categoryId
      ? and(eq(postsTable.status, 'published'), eq(postsTable.categoryId, categoryId))
      : eq(postsTable.status, 'published')
  )
  .orderBy(desc(postsTable.publishedAt));

const posts = await postsQuery;

// Separate featured (first) post from the rest
const featuredPost = posts[0] || null;
const remainingPosts = posts.slice(1);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="blog-main">
      <!-- Blog Header -->
      <section class="blog-header">
        <div class="blog-header-content">
          <h1 class="blog-title">Blog</h1>
          <p class="blog-subtitle">Programming notes, tutorials, and learnings about web development</p>
        </div>
      </section>

      <!-- Category Filter -->
      <section class="category-filter">
        <a
          href="/blog"
          class="category-item {!categoryFilter ? 'active' : ''}"
        >
          All Posts
        </a>
        {allCategories.map((cat) => (
          <a
            href={`/blog?category=${cat.slug}`}
            class:list={["category-item", categoryFilter === cat.slug ? "active" : ""]}
          >
            {cat.icon && <i class={`bi ${cat.icon}`}></i>}
            {cat.name}
          </a>
        ))}
      </section>

      <!-- Featured Post -->
      {featuredPost && !categoryFilter && (
        <section class="featured-post">
          <article class="featured-card">
            {featuredPost.heroImage && (
              <div class="featured-image">
                <img
                  src={featuredPost.heroImage}
                  alt=""
                />
              </div>
            )}
            <div class={featuredPost.heroImage ? "featured-content" : "featured-content featured-content-full"}>
              <span class="featured-badge">
                Latest
              </span>
              <h2 class="featured-title">
                <a href={`/blog/${featuredPost.slug}`}>{featuredPost.title}</a>
              </h2>
              <div class="featured-meta">
                <span class="featured-date">
                  {featuredPost.publishedAt ? (
                    <time datetime={featuredPost.publishedAt.toISOString()}>
                      {featuredPost.publishedAt.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  ) : (
                    <span>No date</span>
                  )}
                </span>
                {featuredPost.authorName && (
                  <span class="featured-author">
                    {featuredPost.authorName}
                  </span>
                )}
              </div>
              <p class="featured-description">{featuredPost.description}</p>
              <a href={`/blog/${featuredPost.slug}`} class="featured-link">
                Read More
              </a>
            </div>
          </article>
        </section>
      )}

      <!-- Category Cards -->
      {allCategories.length > 0 && !categoryFilter && (
        <section class="categories-section">
          <h2 class="section-title">Browse by Topic</h2>
          <div class="categories-grid">
            {allCategories.map((cat) => (
              <a
                href={`/blog?category=${cat.slug}`}
                class="category-card"
              >
                {cat.icon ? (
                  <i class={`bi ${cat.icon} category-icon`}></i>
                ) : (
                  <i class="bi bi-folder category-icon"></i>
                )}
                <h3 class="category-name">{cat.name}</h3>
                {cat.description && (
                  <p class="category-description">{cat.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Category Header when filtering -->
      {categoryFilter && (
        <section class="filter-header">
          <h2 class="filter-title">
            {allCategories.find(c => c.slug === categoryFilter)?.icon && (
              <i class={`bi ${allCategories.find(c => c.slug === categoryFilter)?.icon}`}></i>
            )}
            {allCategories.find(c => c.slug === categoryFilter)?.name || 'Category'}
          </h2>
          <a href="/blog" class="filter-clear">
            Clear filter
          </a>
        </section>
      )}

      <!-- Posts Grid -->
      <section class="posts-section">
        <h2 class="section-title">{categoryFilter ? 'Posts' : 'All Posts'}</h2>

        {posts.length === 0 ? (
          <div class="empty-state">
            <i class="bi bi-journal-x empty-icon"></i>
            <p class="empty-text">No posts yet. Check back soon!</p>
          </div>
        ) : (
          <div class="posts-list">
            {(categoryFilter ? posts : remainingPosts).map((post) => (
              <article class="post-item">
                {post.heroImage && (
                  <div class="post-thumbnail">
                    <img
                      src={post.heroImage}
                      alt=""
                    />
                  </div>
                )}
                <div class="post-item-content">
                  <h3 class="post-item-title">
                    <a href={`/blog/${post.slug}`}>{post.title}</a>
                  </h3>
                  <time class="post-item-date">
                    {post.publishedAt ? (
                      post.publishedAt.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric'
                      })
                    ) : (
                      <span>No date</span>
                    )}
                  </time>
                  <p class="post-item-description">{post.description}</p>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>
    <Footer />

    <style>
      .blog-main {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      /* Blog Header */
      .blog-header {
        text-align: center;
        margin-bottom: 3rem;
      }

      .blog-title {
        font-size: 3rem;
        font-weight: 800;
        color: var(--cyber-text-primary);
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }

      @media (min-width: 768px) {
        .blog-title {
          font-size: 4rem;
        }
      }

      .blog-subtitle {
        font-size: 1.125rem;
        color: var(--cyber-text-secondary);
        max-width: 600px;
        margin: 0 auto;
      }

      /* Category Filter */
      .category-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin-bottom: 4rem;
      }

      .category-item {
        padding: 0.625rem 1.25rem;
        background: var(--cyber-surface);
        color: var(--cyber-text-secondary);
        text-decoration: none;
        border-radius: var(--radius-full);
        font-size: 0.875rem;
        font-weight: 500;
        transition: all var(--motion-duration-normal) var(--motion-ease);
        border: 1px solid transparent;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .category-item:hover {
        background: var(--cyber-surface-hover);
        color: var(--cyber-text-primary);
        border-color: var(--cyber-border-hover);
      }

      .category-item.active {
        background: var(--cyber-primary);
        color: #000;
        border-color: var(--cyber-primary);
      }

      /* Featured Post */
      .featured-post {
        margin-bottom: 4rem;
      }

      .featured-card {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        background: var(--cyber-surface);
        border-radius: var(--radius-xl);
        overflow: hidden;
        border: 1px solid var(--cyber-border-color);
      }

      @media (min-width: 1024px) {
        .featured-card {
          grid-template-columns: 1fr 1fr;
        }
      }

      .featured-image {
        min-height: 300px;
      }

      .featured-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .featured-content {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .featured-content-full {
        grid-column: 1 / -1;
      }

      .featured-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        background: var(--cyber-primary-light);
        color: var(--cyber-primary);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
        align-self: flex-start;
      }

      .featured-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 1rem;
        line-height: 1.2;
      }

      @media (min-width: 768px) {
        .featured-title {
          font-size: 2rem;
        }
      }

      .featured-title a {
        color: var(--cyber-text-primary);
        text-decoration: none;
        transition: color var(--motion-duration-normal) var(--motion-ease);
      }

      .featured-title a:hover {
        color: var(--cyber-primary);
      }

      .featured-meta {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        font-size: 0.875rem;
        color: var(--cyber-text-muted);
      }

      .featured-description {
        color: var(--cyber-text-secondary);
        line-height: 1.6;
        margin-bottom: 1.5rem;
      }

      .featured-link {
        display: inline-flex;
        align-items: center;
        color: var(--cyber-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.875rem;
        transition: color var(--motion-duration-normal) var(--motion-ease);
      }

      .featured-link:hover {
        color: var(--cyber-primary-hover);
        text-decoration: underline;
      }

      /* Categories Section */
      .categories-section {
        margin-bottom: 4rem;
      }

      .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--cyber-text-primary);
        margin-bottom: 1.5rem;
      }

      .categories-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        .categories-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 768px) {
        .categories-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      .category-card {
        padding: 1.5rem;
        background: var(--cyber-surface);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: all var(--motion-duration-normal) var(--motion-ease);
        border: 1px solid transparent;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
      }

      .category-card:hover {
        background: var(--cyber-surface-hover);
        border-color: var(--cyber-border-hover);
        transform: translateY(-2px);
        box-shadow: var(--cyber-shadow-md);
      }

      .category-icon {
        font-size: 2rem;
        color: var(--cyber-primary);
      }

      .category-name {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--cyber-text-primary);
        margin: 0;
      }

      .category-description {
        font-size: 0.875rem;
        color: var(--cyber-text-secondary);
        margin: 0;
        line-height: 1.4;
      }

      /* Filter Header */
      .filter-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .filter-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--cyber-text-primary);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .filter-clear {
        color: var(--cyber-primary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color var(--motion-duration-normal) var(--motion-ease);
      }

      .filter-clear:hover {
        color: var(--cyber-primary-hover);
        text-decoration: underline;
      }

      /* Posts Section */
      .posts-section {
        margin-bottom: 4rem;
      }

      .posts-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      @media (min-width: 768px) {
        .posts-list {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (min-width: 1024px) {
        .posts-list {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      .post-item {
        display: flex;
        flex-direction: column;
        background: var(--cyber-surface);
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid transparent;
        transition: all var(--motion-duration-normal) var(--motion-ease);
      }

      .post-item:hover {
        background: var(--cyber-surface-hover);
        border-color: var(--cyber-border-hover);
        transform: translateY(-2px);
        box-shadow: var(--cyber-shadow-md);
      }

      .post-thumbnail {
        height: 200px;
        overflow: hidden;
      }

      .post-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .post-item-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
      }

      .post-item-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        line-height: 1.3;
      }

      .post-item-title a {
        color: var(--cyber-text-primary);
        text-decoration: none;
        transition: color var(--motion-duration-normal) var(--motion-ease);
      }

      .post-item-title a:hover {
        color: var(--cyber-primary);
      }

      .post-item-date {
        font-size: 0.875rem;
        color: var(--cyber-text-muted);
        margin-bottom: 0.75rem;
      }

      .post-item-description {
        font-size: 0.9375rem;
        color: var(--cyber-text-secondary);
        line-height: 1.5;
        flex-grow: 1;
      }

      /* Empty State */
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
      }

      .empty-icon {
        font-size: 3rem;
        color: var(--cyber-text-muted);
        margin-bottom: 1rem;
      }

      .empty-text {
        color: var(--cyber-text-secondary);
        font-size: 1.125rem;
        margin: 0;
      }

      /* Reduced Motion */
      @media (prefers-reduced-motion: reduce) {
        .category-item,
        .category-card,
        .post-item,
        .featured-card {
          transition: none;
        }
      }
    </style>
  </body>
</html>
