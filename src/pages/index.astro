---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

export const prerender = false;

// Get recent blog posts
const allPosts = (await getCollection('blog')).sort(
	(a, b) => Math.floor(new Date(b.data.pubDate).getTime() / 1000) - Math.floor(new Date(a.data.pubDate).getTime() / 1000)
);
const recentPosts = allPosts.slice(0, 3);
---

<!doctype html>
<html lang="en" data-bs-theme="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero Section - Asymmetric Split -->
		<section class="hero-section">
			<div class="hero-container">
				<div class="hero-content">
					<h1 class="hero-title">
						Exploring the Future of Technology
					</h1>
					<p class="hero-subtitle">
						Deep dives into AI, machine learning, modern frameworks, and cutting-edge development practices. Stay ahead of the curve.
					</p>
					<div class="hero-ctas">
						<a href="/blog" class="hero-cta hero-cta-primary">
							Read Blog
						</a>
						<a href="/about" class="hero-cta hero-cta-secondary">
							About Me
						</a>
					</div>
				</div>
				<div class="hero-visual">
					<div class="code-block">
						<div class="code-comment">// Latest tech insights</div>
						<div class="code-line"><span class="code-keyword">const</span> <span class="code-variable">blog</span> = <span class="code-punctuation">{'{'}</span></div>
						<div class="code-line"><span class="code-indent"></span>focus: [<span class="code-string">'AI'</span>, <span class="code-string">'Coding'</span>, <span class="code-string">'Frameworks'</span>],</div>
						<div class="code-line"><span class="code-indent"></span>mission: <span class="code-string">'Sharing knowledge'</span>,</div>
						<div class="code-line"><span class="code-indent"></span>updated: <span class="code-function">new Date()</span></div>
						<div class="code-line"><span class="code-punctuation">{'}'};</span></div>
						<div class="code-comment">// Stay curious, keep coding</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Stats Section - 4-Column Grid -->
		<section class="stats-section">
			<div class="stats-container">
				<div class="stat-item">
					<div class="stat-icon">
						<i class="bi bi-code-slash"></i>
					</div>
					<div class="stat-number">{allPosts.length}+</div>
					<h3 class="stat-title">Web Dev Deep Dives</h3>
					<p class="stat-description">Frontend and backend tutorials with production-ready patterns</p>
				</div>
				<div class="stat-item">
					<div class="stat-icon">
						<i class="bi bi-briefcase"></i>
					</div>
					<div class="stat-label">Business</div>
					<h3 class="stat-title">Dev Career and Business</h3>
					<p class="stat-description">Freelancing, client work, and thinking like a dev entrepreneur</p>
				</div>
				<div class="stat-item">
					<div class="stat-icon">
						<i class="bi bi-lightbulb"></i>
					</div>
					<div class="stat-label">Tips</div>
					<h3 class="stat-title">Lessons from Work</h3>
					<p class="stat-description">Real-world tips and battle-tested advice from the trenches</p>
				</div>
				<div class="stat-item">
					<div class="stat-icon">
						<i class="bi bi-stack"></i>
					</div>
					<div class="stat-label">Full-Stack</div>
					<h3 class="stat-title">Full-Stack Craft</h3>
					<p class="stat-description">From database design to pixel-perfect UI implementation</p>
				</div>
			</div>
		</section>

		<!-- Topics Section - Different Layout Family -->
		<section class="topics-section">
			<div class="topics-container">
				<h2 class="section-heading">What I Write About</h2>
				<p class="section-subheading">Deep technical content across modern development stacks</p>
				<div class="topics-grid">
					<div class="topic-item">
						<div class="topic-emoji">🤖</div>
						<h3 class="topic-heading">Artificial Intelligence</h3>
						<p class="topic-description">LLMs, transformers, neural networks, and practical AI applications</p>
					</div>
					<div class="topic-item">
						<div class="topic-emoji">💻</div>
						<h3 class="topic-heading">Modern Coding</h3>
						<p class="topic-description">Best practices, clean code, design patterns, and algorithms</p>
					</div>
					<div class="topic-item">
						<div class="topic-emoji">⚡</div>
						<h3 class="topic-heading">Frameworks</h3>
						<p class="topic-description">React, Vue, Astro, Next.js, and emerging frontend tech</p>
					</div>
					<div class="topic-item">
						<div class="topic-emoji">🔧</div>
						<h3 class="topic-heading">Infrastructure</h3>
						<p class="topic-description">Cloud, DevOps, Docker, Kubernetes, and deployment strategies</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Latest Posts Section - Another Layout Family -->
		{recentPosts.length > 0 && (
			<section class="posts-section">
				<div class="posts-container">
					<div class="posts-header">
						<h2 class="section-heading">Latest Articles</h2>
						<p class="section-subheading">Stay updated with the latest in tech</p>
						<a href="/blog" class="view-all-link">View All Posts</a>
					</div>
					<div class="posts-grid">
						{recentPosts.map((post) => (
							<article class="post-card" key={post.id}>
								<div class="post-meta">
									<span class="post-tag">Tech</span>
									<span class="post-read-time">5 min read</span>
								</div>
								<h3 class="post-title">
									<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
								</h3>
								<p class="post-description">{post.data.description}</p>
								<div class="post-footer">
									<time class="post-date">{new Date(post.data.pubDate).toLocaleDateString('en-US', {
										month: 'short',
										day: 'numeric',
										year: 'numeric'
									})}</time>
									<a href={`/blog/${post.slug}/`} class="post-link">Read</a>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>
		)}


		<Footer />
	</body>
</html>

	<style>
		main {
			width: 100%;
			max-width: 100%;
			margin: 0;
			padding: 0;
		}

		/* Hero Section - Asymmetric Split */
		.hero-section {
			min-height: 100vh;
			display: flex;
			align-items: center;
			padding: 6rem 1.5rem 4rem;
			background: var(--cyber-bg-primary);
		}

		.hero-container {
			max-width: 1400px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 1fr;
			gap: 4rem;
			align-items: center;
		}

		@media (min-width: 1024px) {
			.hero-container {
				grid-template-columns: 1fr 1fr;
			}
		}

		.hero-content {
			padding-right: 2rem;
		}

		.hero-title {
			font-size: 2.5rem;
			font-weight: 800;
			line-height: 1.1;
			margin-bottom: 1.5rem;
			color: var(--cyber-text-primary);
			letter-spacing: -0.02em;
		}

		@media (min-width: 768px) {
			.hero-title {
				font-size: 3.5rem;
			}
		}

		@media (min-width: 1024px) {
			.hero-title {
				font-size: 4.5rem;
			}
		}

		.hero-subtitle {
			font-size: 1.125rem;
			line-height: 1.6;
			color: var(--cyber-text-secondary);
			margin-bottom: 2rem;
			max-width: 600px;
		}

		.hero-ctas {
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.hero-cta {
			display: inline-flex;
			align-items: center;
			padding: 0.875rem 1.75rem;
			border-radius: 0.5rem;
			font-weight: 600;
			font-size: 1rem;
			text-decoration: none;
			transition: all var(--motion-duration-normal) var(--motion-ease);
			border: none;
			cursor: pointer;
		}

		.hero-cta-primary {
			background: var(--cyber-primary);
			color: #000;
		}

		.hero-cta-primary:hover {
			background: var(--cyber-primary-hover);
			transform: translateY(-1px);
		}

		.hero-cta-secondary {
			background: transparent;
			color: var(--cyber-text-primary);
			border: 1px solid var(--cyber-border-color);
		}

		.hero-cta-secondary:hover {
			background: var(--cyber-surface);
			border-color: var(--cyber-border-hover);
			color: var(--cyber-primary);
			transform: translateY(-1px);
		}

		.hero-visual {
			display: none;
		}

		@media (min-width: 1024px) {
			.hero-visual {
				display: block;
			}
		}

		/* Code Block Styling */
		.code-block {
			background: var(--cyber-bg-code);
			border: 1px solid var(--cyber-border-color);
			border-radius: var(--radius-lg);
			padding: 1.5rem;
			font-family: var(--font-mono);
			font-size: 0.875rem;
			line-height: 1.6;
			overflow-x: auto;
			box-shadow: var(--cyber-shadow-lg);
		}

		.code-comment {
			color: var(--cyber-text-muted);
			margin-bottom: 0.5rem;
		}

		.code-line {
			margin-bottom: 0.25rem;
		}

		.code-keyword {
			color: #ff7b72;
		}

		.code-variable {
			color: #79c0ff;
		}

		.code-string {
			color: #a5d6ff;
		}

		.code-function {
			color: #d2a8ff;
		}

		.code-punctuation {
			color: var(--cyber-text-secondary);
		}

		.code-indent {
			padding-left: 1.5rem;
		}

		/* Stats Section */
		.stats-section {
			padding: 4rem 1.5rem;
			background: var(--cyber-bg-secondary);
			margin-top: -2rem;
			position: relative;
			z-index: 10;
		}

		.stats-container {
			max-width: 1400px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		@media (min-width: 768px) {
			.stats-container {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (min-width: 1024px) {
			.stats-container {
				grid-template-columns: repeat(4, 1fr);
			}
		}

		.stat-item {
			padding: 1.5rem;
			background: var(--cyber-surface);
			border-radius: var(--radius-lg);
			transition: all var(--motion-duration-normal) var(--motion-ease);
		}

		.stat-item:hover {
			background: var(--cyber-surface-hover);
			transform: translateY(-2px);
			box-shadow: var(--cyber-shadow-md);
		}

		.stat-icon {
			width: 48px;
			height: 48px;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--cyber-primary-light);
			border-radius: var(--radius-md);
			color: var(--cyber-primary);
			font-size: 1.5rem;
			margin-bottom: 1rem;
		}

		.stat-number {
			font-size: 2.5rem;
			font-weight: 800;
			background: var(--cyber-gradient-primary);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
			line-height: 1;
			margin-bottom: 0.5rem;
		}

		.stat-label {
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--cyber-text-muted);
			margin-bottom: 0.5rem;
		}

		.stat-title {
			font-size: 1.125rem;
			font-weight: 700;
			color: var(--cyber-text-primary);
			margin-bottom: 0.5rem;
			line-height: 1.3;
		}

		.stat-description {
			font-size: 0.875rem;
			color: var(--cyber-text-secondary);
			line-height: 1.5;
			margin: 0;
		}

		/* Topics Section */
		.topics-section {
			padding: 6rem 1.5rem;
			background: var(--cyber-bg-primary);
		}

		.topics-container {
			max-width: 1400px;
			margin: 0 auto;
			text-align: center;
		}

		.section-heading {
			font-size: 2.5rem;
			font-weight: 800;
			color: var(--cyber-text-primary);
			margin-bottom: 1rem;
			letter-spacing: -0.02em;
		}

		@media (min-width: 768px) {
			.section-heading {
				font-size: 3rem;
			}
		}

		.section-subheading {
			font-size: 1.125rem;
			color: var(--cyber-text-secondary);
			margin-bottom: 3rem;
			max-width: 600px;
			margin-left: auto;
			margin-right: auto;
		}

		.topics-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.5rem;
			text-align: left;
		}

		@media (min-width: 768px) {
			.topics-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (min-width: 1024px) {
			.topics-grid {
				grid-template-columns: repeat(4, 1fr);
			}
		}

		.topic-item {
			padding: 2rem 1.5rem;
			background: var(--cyber-surface);
			border-radius: var(--radius-lg);
			transition: all var(--motion-duration-normal) var(--motion-ease);
			border: 1px solid transparent;
		}

		.topic-item:hover {
			background: var(--cyber-surface-hover);
			border-color: var(--cyber-border-hover);
			transform: translateY(-2px);
			box-shadow: var(--cyber-shadow-md);
		}

		.topic-emoji {
			font-size: 2.5rem;
			margin-bottom: 1rem;
		}

		.topic-heading {
			font-size: 1.25rem;
			font-weight: 700;
			color: var(--cyber-text-primary);
			margin-bottom: 0.75rem;
			line-height: 1.3;
		}

		.topic-description {
			font-size: 0.9375rem;
			color: var(--cyber-text-secondary);
			line-height: 1.5;
			margin: 0;
		}

		/* Posts Section */
		.posts-section {
			padding: 6rem 1.5rem;
			background: var(--cyber-bg-secondary);
		}

		.posts-container {
			max-width: 1400px;
			margin: 0 auto;
		}

		.posts-header {
			display: flex;
			flex-direction: column;
			gap: 1rem;
			margin-bottom: 3rem;
		}

		@media (min-width: 768px) {
			.posts-header {
				flex-direction: row;
				align-items: flex-end;
				justify-content: space-between;
			}
		}

		.view-all-link {
			color: var(--cyber-primary);
			text-decoration: none;
			font-weight: 600;
			transition: color var(--motion-duration-fast) var(--motion-ease);
		}

		.view-all-link:hover {
			color: var(--cyber-primary-hover);
			text-decoration: underline;
		}

		.posts-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		@media (min-width: 768px) {
			.posts-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (min-width: 1024px) {
			.posts-grid {
				grid-template-columns: repeat(3, 1fr);
			}
		}

		.post-card {
			padding: 1.5rem;
			background: var(--cyber-surface);
			border-radius: var(--radius-lg);
			transition: all var(--motion-duration-normal) var(--motion-ease);
			border: 1px solid transparent;
			display: flex;
			flex-direction: column;
		}

		.post-card:hover {
			background: var(--cyber-surface-hover);
			border-color: var(--cyber-border-hover);
			transform: translateY(-2px);
			box-shadow: var(--cyber-shadow-md);
		}

		.post-meta {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 1rem;
		}

		.post-tag {
			font-size: 0.75rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			padding: 0.25rem 0.5rem;
			background: var(--cyber-primary-light);
			color: var(--cyber-primary);
			border-radius: var(--radius-sm);
		}

		.post-read-time {
			font-size: 0.875rem;
			color: var(--cyber-text-muted);
		}

		.post-title {
			font-size: 1.25rem;
			font-weight: 700;
			color: var(--cyber-text-primary);
			margin-bottom: 0.75rem;
			line-height: 1.3;
		}

		.post-title a {
			color: var(--cyber-text-primary);
			text-decoration: none;
			transition: color var(--motion-duration-fast) var(--motion-ease);
		}

		.post-title a:hover {
			color: var(--cyber-primary);
		}

		.post-description {
			font-size: 0.9375rem;
			color: var(--cyber-text-secondary);
			line-height: 1.5;
			margin-bottom: 1rem;
			flex-grow: 1;
		}

		.post-footer {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-top: auto;
		}

		.post-date {
			font-size: 0.875rem;
			color: var(--cyber-text-muted);
		}

		.post-link {
			color: var(--cyber-primary);
			text-decoration: none;
			font-weight: 600;
			font-size: 0.875rem;
			transition: color var(--motion-duration-fast) var(--motion-ease);
		}

		.post-link:hover {
			color: var(--cyber-primary-hover);
			text-decoration: underline;
		}

		/* Reduced Motion Support */
		@media (prefers-reduced-motion: reduce) {
			.hero-cta,
			.stat-item,
			.topic-item,
			.post-card {
				transition: none;
			}
		}
	</style>
